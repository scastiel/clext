{
  "name": "clext",
  "displayName": "CLext",
  "description": "Claude Code diff navigator for VSCode",
  "version": "0.0.1",
  "publisher": "clext",
  "engines": {
    "vscode": "^1.84.0"
  },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "clext",
          "title": "CLext",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "clext": [
        {
          "id": "clext.changedFiles",
          "name": "Changed Files"
        },
        {
          "id": "clext.reviewComments",
          "name": "Review Comments"
        }
      ]
    },
    "commands": [
      {
        "command": "clext.switchMode.working",
        "title": "Working Changes",
        "icon": "$(edit)"
      },
      {
        "command": "clext.switchMode.working.active",
        "title": "Working Changes (active)",
        "icon": "$(circle-filled)"
      },
      {
        "command": "clext.switchMode.lastCommit",
        "title": "Last Commit",
        "icon": "$(git-commit)"
      },
      {
        "command": "clext.switchMode.lastCommit.active",
        "title": "Last Commit (active)",
        "icon": "$(circle-filled)"
      },
      {
        "command": "clext.switchMode.branch",
        "title": "vs Main",
        "icon": "$(git-compare)"
      },
      {
        "command": "clext.switchMode.branch.active",
        "title": "vs Main (active)",
        "icon": "$(circle-filled)"
      },
      {
        "command": "clext.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "clext.collapseAll",
        "title": "Collapse All",
        "icon": "$(collapse-all)"
      },
      {
        "command": "clext.expandAll",
        "title": "Expand All",
        "icon": "$(expand-all)"
      },
      {
        "command": "clext.addReviewComment",
        "title": "Add Review Comment"
      },
      {
        "command": "clext.addGlobalReviewComment",
        "title": "Add Global Comment",
        "icon": "$(add)"
      },
      {
        "command": "clext.addFileReviewComment",
        "title": "Add Review Comment"
      },
      {
        "command": "clext.copyReviewComments",
        "title": "Copy All Comments",
        "icon": "$(clippy)"
      },
      {
        "command": "clext.clearReviewComments",
        "title": "Clear All Comments",
        "icon": "$(clear-all)"
      },
      {
        "command": "clext.removeReviewComment",
        "title": "Remove Comment",
        "icon": "$(close)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "clext.switchMode.working",
          "when": "view == clext.changedFiles && clext.mode != working",
          "group": "navigation@1"
        },
        {
          "command": "clext.switchMode.working.active",
          "when": "view == clext.changedFiles && clext.mode == working",
          "group": "navigation@1"
        },
        {
          "command": "clext.switchMode.lastCommit",
          "when": "view == clext.changedFiles && clext.mode != lastCommit",
          "group": "navigation@2"
        },
        {
          "command": "clext.switchMode.lastCommit.active",
          "when": "view == clext.changedFiles && clext.mode == lastCommit",
          "group": "navigation@2"
        },
        {
          "command": "clext.switchMode.branch",
          "when": "view == clext.changedFiles && clext.mode != branch",
          "group": "navigation@3"
        },
        {
          "command": "clext.switchMode.branch.active",
          "when": "view == clext.changedFiles && clext.mode == branch",
          "group": "navigation@3"
        },
        {
          "command": "clext.collapseAll",
          "when": "view == clext.changedFiles && !clext.treeCollapsed",
          "group": "navigation@4"
        },
        {
          "command": "clext.expandAll",
          "when": "view == clext.changedFiles && clext.treeCollapsed",
          "group": "navigation@4"
        },
        {
          "command": "clext.refresh",
          "when": "view == clext.changedFiles",
          "group": "navigation@5"
        },
        {
          "command": "clext.addGlobalReviewComment",
          "when": "view == clext.reviewComments",
          "group": "navigation@1"
        },
        {
          "command": "clext.copyReviewComments",
          "when": "view == clext.reviewComments",
          "group": "navigation@2"
        },
        {
          "command": "clext.clearReviewComments",
          "when": "view == clext.reviewComments",
          "group": "navigation@3"
        }
      ],
      "editor/context": [
        {
          "command": "clext.addReviewComment",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "clext.removeReviewComment",
          "when": "view == clext.reviewComments",
          "group": "inline"
        },
        {
          "command": "clext.addFileReviewComment",
          "when": "view == clext.changedFiles && viewItem == changedFile",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "CLext",
      "properties": {
        "clext.baseBranch": {
          "type": "string",
          "default": "main",
          "description": "Base branch for the \"vs Main\" diff mode"
        }
      }
    }
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "watch": "npm run build -- --watch",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "package": "vsce package",
    "vscode:prepublish": "npm run build -- --minify"
  },
  "devDependencies": {
    "@types/vscode": "^1.84.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.5.0"
  }
}
